{
  "$schema": "https://openapi.vercel.sh/vercel.json",
  "framework": null,
  "installCommand": "npm ci",
  "buildCommand": "npm run vercel-build",
  "outputDirectory": "dist",
  "rewrites": [
    { "source": "/api/account", "destination": "/api/admin?__route=account" },
    { "source": "/api/analytics", "destination": "/api/admin?__route=analytics" },
    { "source": "/api/audit", "destination": "/api/admin?__route=audit" },
    { "source": "/api/backup", "destination": "/api/admin?__route=backup" },
    { "source": "/api/categories", "destination": "/api/admin?__route=categories" },
    { "source": "/api/entities", "destination": "/api/admin?__route=entities" },
    { "source": "/api/imports", "destination": "/api/admin?__route=imports" },
    { "source": "/api/media", "destination": "/api/admin?__route=media" },
    { "source": "/api/notifications", "destination": "/api/admin?__route=notifications" },
    { "source": "/api/orders", "destination": "/api/admin?__route=orders" },
    { "source": "/api/tender-bids", "destination": "/api/admin?__route=tender-bids" },
    { "source": "/api/tenders", "destination": "/api/admin?__route=tenders" },
    { "source": "/api/users", "destination": "/api/admin?__route=users" }
  ],
  "functions": {
    "api/*.js": {
      "maxDuration": 30
    }
  },
  "crons": [
    {
      "path": "/api/cron-price-freshness",
      "schedule": "15 2 * * *"
    },
    {
      "path": "/api/cron-notifications",
      "schedule": "30 2 * * *"
    }
  ],
  "headers": [
    {
      "source": "/(.*)",
      "headers": [
        { "key": "X-Content-Type-Options", "value": "nosniff" },
        { "key": "X-Frame-Options", "value": "SAMEORIGIN" },
        { "key": "Referrer-Policy", "value": "strict-origin-when-cross-origin" },
        { "key": "Permissions-Policy", "value": "camera=(), microphone=(), geolocation=()" },
        { "key": "Strict-Transport-Security", "value": "max-age=31536000; includeSubDomains" }
      ]
    }
  ]
}
