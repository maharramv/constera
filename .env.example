# Vercel Marketplace > Neon inteqrasiyası bu ünvanı avtomatik yarada bilər.
DATABASE_URL=

# İlk super administratorun təhlükəsiz yaradılması üçün ən azı 32 simvolluq gizli açar.
ADMIN_SETUP_TOKEN=

# Vercel Cron sorğularını qorumaq üçün gizli açar.
CRON_SECRET=

# Məhsul şəkilləri və sənədlər üçün Vercel Blob açarı.
BLOB_READ_WRITE_TOKEN=

# Bildirişlər üçün n8n/inteqrasiya webhook-ları. Boş olduqda bildiriş növbədə saxlanır.
EMAIL_WEBHOOK_URL=
WHATSAPP_WEBHOOK_URL=
NOTIFICATION_WEBHOOK_SECRET=
ADMIN_NOTIFICATION_EMAIL=
ADMIN_NOTIFICATION_PHONE=

# Könüllü ayarlar
SESSION_COOKIE_NAME=constera_session
APP_ORIGIN=https://constera.az
